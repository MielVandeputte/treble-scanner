{
  "name": "treble-scanner",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc && vite build",
    "start": "vite preview",
    "check:format": "prettier --check \"**/*.{js,tsx,ts,css,jsx,json}\"",
    "check:lint": "eslint",
    "check": "npm run check:format && npm run check:lint",
    "fix:format": "prettier --write \"**/*.{js,tsx,ts,css,jsx,json}\"",
    "fix:lint": "eslint --fix",
    "fix": "npm run fix:format && npm run fix:lint",
    "test:vitest": "vitest run",
    "test:playwright": "npx playwright test",
    "test": "npm run test:vitest && npm run test:playwright",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.svg"
  },
  "dependencies": {
    "@fontsource/proza-libre": "5.2.7",
    "clsx": "2.1.1",
    "motion": "12.38.0",
    "qr-scanner": "1.4.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-router-dom": "7.14.1",
    "store2": "2.14.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.58.2",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unicorn": "63.0.0",
    "@faker-js/faker": "10.4.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.1",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.4"
  }
